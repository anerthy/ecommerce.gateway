{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "orden-venta": {
        "ClusterId": "mam",
        "Match": {
          "Path": "/api/factura/orden-venta"
        },
        "Transforms": [
          {
            "PathSet": "/api/factura/CreaOrdenVenta"
          }
        ]
      },
      "articulos": {
        "ClusterId": "mdm",
        "Match": {
          "Path": "/api/articulos"
        },
        "Transforms": [
          {
            "PathSet": "/api/netsuite/inventario/ObtenerArticulos"
          }
        ]
      },
      "utilidades-provincia": {
        "ClusterId": "mdm",
        "Match": {
          "Path": "/api/utilidades/provincias"
        },
        "Transforms": [
          {
            "PathSet": "/api/netsuite/Utilidades/Provincia"
          }
        ]
      },
      "utilidades-cantones": {
        "ClusterId": "mdm",
        "Match": {
          "Path": "/api/utilidades/cantones"
        },
        "Transforms": [
          {
            "PathSet": "/api/netsuite/Utilidades/Cantones"
          }
        ]
      },
      "utilidades-distritos": {
        "ClusterId": "mdm",
        "Match": {
          "Path": "/api/utilidades/distritos"
        },
        "Transforms": [
          {
            "PathSet": "/api/netsuite/Utilidades/Distritos"
          }
        ]
      },
      "utilidades-pueblos": {
        "ClusterId": "mdm",
        "Match": {
          "Path": "/api/utilidades/pueblos"
        },
        "Transforms": [
          {
            "PathSet": "/api/netsuite/Utilidades/Pueblos"
          }
        ]
      }
    },
    "Clusters": {
      "mam": {
        "Destinations": {
          "destination1": {
            "Address": "https://cg2dev-webappmam-keycloak.azurewebsites.net"
          }
        }
      },
      "mam_erp": {
        "Destinations": {
          "destination1": {
            "Address": "https://cg2dev-webappmam-erp.azurewebsites.net"
          }
        }
      },
      "mdm": {
        "Destinations": {
          "destination1": {
            "Address": "https://cg2-dev-webappmdm-keycloak.azurewebsites.net"
          }
        }
      },
      "mdm_erp": {
        "Destinations": {
          "destination1": {
            "Address": "https://cg2-dev-webappmdm-erp.azurewebsites.net"
          }
        }
      }
    }
  }
}
